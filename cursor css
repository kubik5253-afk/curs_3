.custom-cursor {
  position: fixed;
  top: 0;
  left: 0;
  width: 100px; /* Ширина вашего курсора */
  height: 100px; /* Высота вашего курсора */
  pointer-events: none; /* Чтобы клики проходили сквозь курсор */
  z-index: 9999; /* Поверх всех элементов */
  transform: translate(-50%, -50%); /* Центрируем картинку */
  transition: transform 0.1s ease-out; /* Плавность движения */
}

.custom-cursor img {
  width: 100%;
  height: 100%;
  display: block;
}
